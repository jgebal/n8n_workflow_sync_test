    {
      "parameters": {
        "jsCode": "const workflow_id = $('If n8n before ADO').first().json.same.id;\n\nconst all_decoded = $('Get a workflow version').all();\n\nconst matched = all_decoded.filter(item => item.json.id === workflow_id);\n\nif (matched.length > 0) {\n  return [{ json: { dataset: matched[0].json } }];\n} else {\n  return [];\n}"
